{
  "name": "doomstack",
  "version": "0.1.0",
  "description": "Accessible, security-first React Native UI primitives (WCAG AA, SAST-clean by default).",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "!**/__tests__"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "react-native",
    "accessibility",
    "wcag",
    "ui-components",
    "security"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glitch-12/doomstack.git"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.71"
  },
  "devDependencies": {
    "@babel/core": "^7.24.9",
    "@react-native/babel-preset": "^0.75.0",
    "@testing-library/react-native": "^12.5.0",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.79",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-native-a11y": "^3.4.1",
    "jest": "^29.7.0",
    "react": "18.2.0",
    "react-native": "0.75.0",
    "react-test-renderer": "18.2.0",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
